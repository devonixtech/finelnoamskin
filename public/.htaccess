# ============================================================
# NoamSkin cPanel .htaccess — Cache Busting Configuration
# ============================================================

# Enable Rewrite Engine (required for React SPA routing)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve existing files/directories directly
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Route all other requests to index.html (React Router)
  RewriteRule ^ index.html [QSA,L]
</IfModule>

# ============================================================
# CACHE HEADERS: Force browsers to always check for updates
# ============================================================

<IfModule mod_headers.c>

  # index.html — NEVER cache. Always fetch fresh copy.
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # JS & CSS — Vite gives them unique hashes (e.g. main-abc123.js)
  # So it's safe to cache them for 1 year.
  <FilesMatch "\.(js|css|mjs)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Images, fonts — cache 30 days
  <FilesMatch "\.(png|jpg|jpeg|gif|svg|ico|webp|woff|woff2|ttf|eot)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # manifest.json & sw.js — always check for updates
  <FilesMatch "^(manifest\.json|sw\.js)$">
    Header set Cache-Control "no-cache, must-revalidate"
    Header set Expires "0"
  </FilesMatch>

</IfModule>

# Fallback via mod_expires if mod_headers not available
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML: no cache
  ExpiresByType text/html "access plus 0 seconds"

  # JS / CSS: 1 year (hash-based filenames)
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"

  # Images: 30 days
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/gif "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/x-icon "access plus 30 days"

  # Fonts: 1 year
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Enable GZIP Compression (faster loads)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>
